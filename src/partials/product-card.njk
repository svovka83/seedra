{% macro productCard (  ) %}
  <div class="product-card">
    <img class="product-card__img" src="/images/products/product_1.jpg" alt="product card image" />

    <div class="product-card__content">
      <div class="product-card__top">
        <div class="product-card__ranking">
          <svg class="product-card__icon-star">
            <use xlink:href="/images/sprites.svg#star-full-icon"></use>
          </svg>
          <svg class="product-card__icon-star">
            <use xlink:href="/images/sprites.svg#star-full-icon"></use>
          </svg>
          <svg class="product-card__icon-star">
            <use xlink:href="/images/sprites.svg#star-full-icon"></use>
          </svg>
          <svg class="product-card__icon-star">
            <use xlink:href="/images/sprites.svg#star-full-icon"></use>
          </svg>
          <svg class="product-card__icon-star">
            <use xlink:href="/images/sprites.svg#star-half-icon"></use>
          </svg>
        </div>
        <span class="product-card__quantity">(123)</span>
      </div>

      <div class="product-card__title">
        <!-- title ( heading, title, classTitle ) -->
        {% from "src/partials/title.njk" import title %}
        {{ title( "h4", "Seedra Cilantro Seeds for Planting Indoor and Outdoor", "title_card") }}
      </div>

      <div class="product-card__bottom">
        <span class="product-card__price">$12.56</span>

        <div class="product-card__button">
          <!-- button ( classBtn, titleBtn, iconId ) -->
          {% from "src/partials/button.njk" import button %}
          {{ button( "btn_icon", "", "cart-icon" ) }}
        </div>
      </div>
    </div>

    <div class="product-card__yellow-heart">
      <svg class="product-card__icon-heart">
        <use xlink:href="/images/sprites.svg#heart-icon"></use>
      </svg>
    </div>

  </div>
{% endmacro %}