{% macro dropdown( title, initial, initialID, listID, classPrice, option1, option2, option3, option4, classNoOption ) %}
  <div class="dropdown">
    <div class="dropdown__control">
      <div class="dropdown__title-block">
        <p class="dropdown__title">{{ title }}</p>
        <p class="dropdown__initial" id="{{ initialID }}">{{ initial }}</p>
      </div>
      <svg class="dropdown__icon">
        <use xlink:href="/images/sprites.svg#chevron-icon"></use>
      </svg>
    </div>
    
    <div class="dropdown__list" id="{{ listID }}">
      <div class="dropdown__option">
        <span class="dropdown__value">{{ option1 }}</span>
        <span class="dropdown__price {{classPrice}}">+$0</span>
      </div>
      <div class="dropdown__option">
        <span class="dropdown__value">{{ option2 }}</span>
        <span class="dropdown__price {{classPrice}}">+$20</span>
      </div>
      <div class="dropdown__option {{classNoOption}}">
        <span class="dropdown__value">{{ option3 }}</span>
        <span class="dropdown__price {{classPrice}}">+$50</span>
      </div>
      <div class="dropdown__option {{classNoOption}}">
        <span class="dropdown__value">{{ option4 }}</span>
        <span class="dropdown__price {{classPrice}}">+$100</span>
      </div>
    </div>
	</div>
{% endmacro %}
