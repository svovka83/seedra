{% macro search ( classSearch, searchFunnelId, searchInputId ) %}
  <div class="search {{classSearch}}">
    <input class="search__input" type="text" id="{{ searchInputId }}" placeholder="Search">
    <svg class="search__close">
	    <use xlink:href="/images/sprites.svg#close-icon"></use>
    </svg>
    <svg class="search__icon">
	    <use xlink:href="/images/sprites.svg#search-icon"></use>
    </svg>
    <img class="search__img" src="/images/icons/funnel.svg" id="{{ searchFunnelId }}" alt="search icon funnel">
  </div>
{% endmacro %}
