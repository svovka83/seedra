{% macro filterDropdown( title, option1, option2, option3 ,option4 ) %}
	<div class="filter-dropdown">

    <button class="filter-dropdown__btn">
      <span class="filter-dropdown__title">{{ title }}</span>
      <svg class="filter-dropdown__icon">
        <use href="/images/sprites.svg#chevron-icon"></use>
      </svg>
    </button>

    <div class="filter-dropdown__content">
      <div class="filter-dropdown__inner">

        <!-- checkbox( title ) -->
		    {% from "src/partials/checkbox.njk" import checkbox %}

        <div class="filter-dropdown__option">
          {{ checkbox( option1 ) }}
        </div>
        <div class="filter-dropdown__option">
          {{ checkbox( option2 ) }}
        </div>
        <div class="filter-dropdown__option">
          {{ checkbox( option3 ) }}
        </div>
        <div class="filter-dropdown__option">
          {{ checkbox( option4 ) }}
        </div>
      </div>
    </div>

	</div>
{% endmacro %}
